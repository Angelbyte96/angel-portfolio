---
import { getCollection } from 'astro:content'

export const getStaticPaths = async () => {
	const allProyects = await getCollection('allProyects')

	return allProyects.map(proyect => ({
		params: { id: proyect.slug },
		props: { proyect }
	}))
}

const { proyect } = Astro.props
const { data } = proyect
const { title } = data
---

<!doctype html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>{`${title}`}</title>
	</head>
	<body class='min-h-screen bg-fixed bg-custom-gradient font-serif'>
		<h1 class='text-white'>{`${title}`}</h1>
	</body>
</html>
