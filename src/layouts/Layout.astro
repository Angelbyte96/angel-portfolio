---
import Footer from '@/components/Footer.astro'
import Nav from '@/components/Nav.astro'
import '@/styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
	title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width' />
		<link rel='icon' type='image/svg+xml' href='/avatar.webp' />
		<meta name='generator' content={Astro.generator} />
		<link rel='canonical' href='https://angelbyte.dev/' />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body
		class='grid grid-rows-[auto_1fr_auto] h-dvh dark:bg-black min-h-screen bg-scroll md:bg-fixed selection:bg-fuchsia-700 font-monda'>
		<Nav />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
<style>
	html,
	body {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}
</style>
