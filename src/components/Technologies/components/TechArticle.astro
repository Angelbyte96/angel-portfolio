---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'article'> {
	title: string
}

const { title, class: className, ...rest } = Astro.props
---

<article
	class:list={[
		'flex flex-col justify-start items-center py-4 px-2 md:py-4 md:px-2 md:border-solid border border-[#0f172a] gap-4 bg-fuchsia-950 backdrop-opacity-5 backdrop-blur-lg rounded-lg',
		className
	]}
	{...rest}>
	<h1 class='text-[#2cc9ff] font-bold text-xl md:text-2xl'>{title}</h1>
	<ul class='flex flex-wrap justify-center items-center gap-4'>
		<slot />
	</ul>
</article>
